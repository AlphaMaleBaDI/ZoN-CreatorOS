# ZoN CreatorOS - Environment Config
# Copy this to .env and fill in your keys.

# Production Engine
# Options: "template" | "amd"
PRODUCTION_ENGINE=template

# Fireworks AI (AMD inference backend)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v3p1

# Workspace configuration
WORKSPACE_STORAGE_DIR=./workspace_db
FAISS_STORAGE_PATH=./workspace_db/vector_store
