# ZoN CreatorOS - Environment Config
# Copy this to .env and fill in your keys.

# Model Router configuration
# Options: "local" (Ryzen AI NPU) | "cloud" (AMD Instinct GPUs)
CREATOROS_INFERENCE_MODE=local

# Production Engine
# Options: "template" | "amd"
PRODUCTION_ENGINE=template

# AMD Cloud Endpoint (for AMDEngine)
AMD_CLOUD_INFERENCE_URL=https://your-amd-instance:8000/v1
AMD_CLOUD_API_KEY=your_amd_cloud_key_here

# Workspace configuration
WORKSPACE_STORAGE_DIR=./workspace_db
FAISS_STORAGE_PATH=./workspace_db/vector_store
